generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  @@map("users")
}

// RAG (Retrieval-Augmented Generation) — dokumen untuk basis pengetahuan AI
model RagDocument {
  id        String   @id @default(uuid())
  title     String
  content   String
  source    String   @default("manual") // manual, faq, course_material, website, other
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rag_documents")
}